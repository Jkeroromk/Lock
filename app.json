{
  "expo": {
    "name": "Lock",
    "slug": "lock",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "icon": "./assets/dark-lockin.png",
    "splash": {
      "image": "./assets/dark-lockin.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jkeroro.lockin",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Lock reads your step count and active energy to display daily activity and sync it to your personal account.",
        "NSHealthUpdateUsageDescription": "Lock writes workout and nutrition data to Apple Health to keep your records complete.",
        "NSCameraUsageDescription": "Lock uses the camera to photograph meals for AI-powered calorie analysis.",
        "NSPhotoLibraryUsageDescription": "Lock accesses your photo library to choose a meal photo or profile picture.",
        "NSPhotoLibraryAddUsageDescription": "Lock saves meal photos to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/dark-lockin.png",
        "backgroundColor": "#000000"
      },
      "package": "com.jkeroro.lockin",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "favicon": "./assets/dark-lockin.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Lock accesses your photo library to choose meal photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Lock uses the camera to photograph meals for calorie analysis."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#007AFF",
          "defaultChannel": "default"
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-alternate-app-icons",
        [
          { "name": "DarkLockin", "image": "./assets/dark-lockin.png" },
          { "name": "WhiteLockin", "image": "./assets/white-lockin.png" }
        ]
      ]
    ],
    "scheme": "lock",
    "extra": {
      "eas": {
        "projectId": "6bddb492-55a5-4ae0-856d-ec4b27314127"
      },
      "router": {}
    },
    "owner": "jkeroro"
  }
}
