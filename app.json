{
  "expo": {
    "name": "Lock",
    "slug": "lock",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "icon": "./assets/dark-lockin.jpg",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jkeroro.lockin",
      "infoPlist": {
        "NSHealthShareUsageDescription": "我们需要访问您的健康数据以跟踪您的步数、活动能量和心率。",
        "NSHealthUpdateUsageDescription": "我们需要更新您的健康数据以记录您的活动。",
        "NSCameraUsageDescription": "我们需要访问相机以拍摄食物照片。",
        "NSPhotoLibraryUsageDescription": "我们需要访问相册以选择食物照片。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "package": "com.jkeroro.lockin",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "允许访问相册以选择食物照片"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "允许访问相机以拍摄食物照片"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#007AFF",
          "defaultChannel": "default"
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-alternate-app-icons",
        [
          { "name": "DarkLockin", "image": "./assets/dark-lockin.jpg" },
          { "name": "WhiteLockin", "image": "./assets/white-lockin.jpg" }
        ]
      ]
    ],
    "scheme": "lock",
    "extra": {
      "eas": {
        "projectId": "6bddb492-55a5-4ae0-856d-ec4b27314127"
      },
      "router": {}
    },
    "owner": "jkeroro"
  }
}
