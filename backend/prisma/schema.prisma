generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id           // Clerk user ID: "user_2xxx"
  email     String?  @unique
  name      String?
  username   String?  @unique
  bio        String?
  avatarEmoji String? @map("avatar_emoji")
  showGender  Boolean @default(false) @map("show_gender")
  inviteCode String? @unique @map("invite_code")
  streak    Int      @default(0)
  height    Int?
  age       Int?
  weight    Decimal? @db.Decimal(5, 2)
  gender    String?
  goal      String?
  exerciseFrequency  String?  @map("exercise_frequency")
  expectedTimeframe  String?  @map("expected_timeframe")
  hasCompletedOnboarding Boolean @default(false) @map("has_completed_onboarding")
  plan         String   @default("FREE") // FREE | PRO | ENTERPRISE
  subscription String?  // RevenueCat subscription product ID
  aiCallsToday    Int      @default(0) @map("ai_calls_today")
  aiCallsResetAt  DateTime @default(now()) @map("ai_calls_reset_at") @db.Timestamptz(6)
  pushToken       String?  @map("push_token")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  meals                 Meal[]
  healthSyncs           HealthSync[]
  sentFriendRequests    Friendship[] @relation("FriendshipRequester")
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")
  challenges            ChallengeParticipant[]
  createdChallenges     Challenge[]
  activityFeed          ActivityFeed[]
  weightRecords         WeightRecord[]

  @@map("users")
}

model Meal {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  foodName  String   @map("food_name")
  calories  Decimal  @default(0) @db.Decimal(10, 2)
  protein   Decimal? @default(0) @db.Decimal(10, 2)
  carbs     Decimal? @default(0) @db.Decimal(10, 2)
  fat       Decimal? @default(0) @db.Decimal(10, 2)
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("meals")
}

model Friendship {
  id          String   @id @default(uuid()) @db.Uuid
  requesterId String   @map("requester_id")
  addresseeId String   @map("addressee_id")
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@map("friendships")
}

model Challenge {
  id          String   @id @default(uuid()) @db.Uuid
  creatorId   String   @map("creator_id")
  title       String
  description String?
  type        String   @default("CALORIES") // CALORIES, STREAK, STEPS
  goalValue   Int      @map("goal_value")
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  creator      User                   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]

  @@index([creatorId])
  @@map("challenges")
}

model ChallengeParticipant {
  id          String   @id @default(uuid()) @db.Uuid
  challengeId String   @map("challenge_id") @db.Uuid
  userId      String   @map("user_id")
  progress    Int      @default(0)
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
  @@map("challenge_participants")
}

model ActivityFeed {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  type      String   // MEAL_LOGGED, GOAL_REACHED, STREAK_MILESTONE, CHALLENGE_JOINED, CHALLENGE_COMPLETED
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_feed")
}

model WeightRecord {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id")
  weight     Decimal  @db.Decimal(5, 2)        // kg
  note       String?
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recordedAt])
  @@map("weight_records")
}

model Food {
  id        String   @id @default(uuid()) @db.Uuid
  name      String                                    // 食物名称（中文或英文）
  nameEn    String?  @map("name_en")                 // 英文名（来自 USDA）
  calories  Decimal  @db.Decimal(10, 2)              // kcal per 100g
  protein   Decimal  @default(0) @db.Decimal(10, 2)  // g per 100g
  carbs     Decimal  @default(0) @db.Decimal(10, 2)  // g per 100g
  fat       Decimal  @default(0) @db.Decimal(10, 2)  // g per 100g
  source    String   @default("LOCAL")               // LOCAL | USDA
  fdcId     String?  @unique @map("fdc_id")          // USDA FoodData Central ID
  cachedAt  DateTime? @map("cached_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([name])
  @@index([source])
  @@map("foods")
}

model HealthSync {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id")
  date         DateTime @db.Date
  steps        Int      @default(0)
  activeEnergy Decimal  @default(0) @map("active_energy") @db.Decimal(10, 2)
  heartRate    Int      @default(0) @map("heart_rate")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("health_sync")
}
