# Backend Environment Variables
# Copy this file to .env.local and fill in your values

# Clerk Authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Fireworks AI API (https://fireworks.ai)
FIREWORKS_API_KEY=fw_...

# USDA FoodData Central API (https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=your_usda_key_here

# Database (PostgreSQL / Prisma Accelerate connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/lock_db
